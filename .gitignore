# Built output. All of it is regenerated by build.py from the sources in this repo
# plus the copy of the game and the mods already installed on your own machine.
# None of it belongs in version control: these are Bethesda's and the mod authors'
# files with our text substituted in, not our files.
*.esm
*.esp
*.ESP
*.esp.*
*.omwaddon
*.omwgame
Fonts/*.ttf

# Working copies and backups
_backup*/
*.bak
*.bak-*
*.mrk
*.orig

# tools/base.esm is the 80 MB partially-Ukrainian Morrowind.esm this project started
# from; tools/corpus.json is the raw dialogue dump regenerated from it.
tools/base.esm
tools/corpus.json

# Local machine paths
config.json

# Python
__pycache__/
*.py[cod]
.venv/
venv/
